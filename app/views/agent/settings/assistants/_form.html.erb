<%= form_with(model: assistant, url: assistant.persisted? ? settings_assistant_path(assistant) : settings_assistants_path, class: "contents") do |form| %>
  <% if assistant.errors.any? %>
    <div id="error_explanation" class="bg-red-50 text-red-500 px-3 py-2 font-medium rounded-lg mt-3">
  <h2><%= t('app.settings.assistants.form.errors_title', count: assistant.errors.count) %></h2>

      <ul>
        <% assistant.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="my-5">
  <%= form.label :name, t('app.settings.assistants.form.name') %>
    <%= form.text_field :name,
      autofocus: assistant.new_record?,
      class: %|
        block w-full
        border border-gray-200 outline-none
        shadow rounded-md
        px-3 py-2 mt-2
        dark:text-black
      | %>
  </div>

  <% unless assistant.new_record? %>
    <div class="my-5">
  <%= form.label :slug, t('app.settings.assistants.form.slug') %>
      <%= form.text_field :slug,
        autofocus: assistant.new_record?,
        class: %|
          block w-full
          border border-gray-200 outline-none
          shadow rounded-md
          px-3 py-2 mt-2
          dark:text-black
        | %>
    </div>
  <% end %>

  <div class="my-5">
  <%= form.label :provider_name, t('app.settings.assistants.form.provider_name') %>
    <%= form.text_field :provider_name, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full dark:text-black" %>
  </div>

  <div class="my-5">
  <%= form.label :driver, t('app.settings.assistants.form.driver') %>
    <%= form.select :driver,
      Agent::Assistant.drivers.keys.map { |d| [d.capitalize, d] },
      {},
      class: %|
        block
        border border-gray-200 outline-none
        shadow rounded-md
        px-3 py-2 mt-2
        w-full
        dark:text-black
    | %>
  </div>

  <div class="my-5">
  <%= form.label :url, t('app.settings.assistants.form.url') %>
    <%= form.text_field :url, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full dark:text-black" %>
  </div>

  <div class="my-5">
  <%= form.label :token, t('app.settings.assistants.form.token') %>
    <%= form.password_field :token, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full dark:text-black" %>
  </div>

  <div class="my-5">
  <%= form.label :api_name, t('app.settings.assistants.form.api_name') %>
    <%= form.text_field :api_name, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full dark:text-black" %>
  </div>

  <div class="my-5 flex gap-4">
    <label class="flex items-center gap-2">
      <%= form.check_box :supports_images %> <%= t('app.settings.assistants.form.supports_images') %>
    </label>
    <label class="flex items-center gap-2">
      <%= form.check_box :supports_tools %> <%= t('app.settings.assistants.form.supports_tools') %>
    </label>
    <label class="flex items-center gap-2">
      <%= form.check_box :supports_system_message %> <%= t('app.settings.assistants.form.supports_system_message') %>
    </label>
    <label class="flex items-center gap-2">
      <%= form.check_box :supports_pdf %> <%= t('app.settings.assistants.form.supports_pdf') %>
    </label>
  </div>

  <div class="my-5">
  <%= form.label :description, t('app.settings.assistants.form.description') %>
    <%= form.text_field :description, class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full dark:text-black" %>
  </div>

  <div class="my-5">
  <%= form.label :instructions, t('app.settings.assistants.form.instructions') %>
    <%= form.text_area :instructions,
      autofocus: assistant.persisted?,
      class: %|
        block w-full
        border border-gray-200 outline-none
        shadow rounded-md
        px-3 py-2 mt-2
        dark:text-black
        h-18
        overflow-y-auto
      |,
      data: {
        controller: "textarea-autogrow",
        action: %|
          keydown.meta+enter->textarea-autogrow#submitForm
          keydown.ctrl+enter->textarea-autogrow#submitForm
        |
      }
    %>
  </div>

  <%= form.submit t('app.settings.assistants.form.save'),
    class: %|
      inline-block font-bold
      bg-gray-200 dark:bg-gray-900
      border border-gray-400
      rounded-lg py-3 px-5
      cursor-pointer
    |,
  data: { turbo_submits_with: t('app.settings.assistants.form.saving') }
  %>
<% end %>
